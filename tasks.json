{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cppbuild",
			"label": "C/C++: g++.exe build active file",
			"command": "C:\\MinGW\\bin\\g++.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"C:\\MinGW\\lib\\glad.c",
				"C:\\MinGW\\lib\\libglfw3.a",
				"C:\\MinGW\\lib\\libgdi32.a",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe",
				"-L",
				"-lopengl32",
				"-luser32",
				"-lshell32"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": "build",
			"detail": "compiler: C:\\MinGW\\bin\\g++.exe"
		}
	]
}